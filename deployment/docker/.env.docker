# Docker Compose Environment Configuration
# This file is used by docker-compose.yml to configure services
# Copy to .env in this directory for docker-compose to use automatically

# ==============================================================================
# REQUIRED: API Keys and Security
# ==============================================================================

# Anthropic API Key (REQUIRED for AI features)
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Encryption Keys (REQUIRED for API key security)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SOCRATES_ENCRYPTION_KEY=change-me-to-secure-random-key-32-chars
DATABASE_ENCRYPTION_KEY=change-me-to-secure-random-key-32-chars

# ==============================================================================
# DATABASE
# ==============================================================================

# PostgreSQL Configuration
POSTGRES_USER=socrates
POSTGRES_PASSWORD=socrates_dev_password
POSTGRES_DB=socrates_db

# ==============================================================================
# SERVICES
# ==============================================================================

# Environment
ENVIRONMENT=development
LOG_LEVEL=INFO

# Redis
REDIS_URL=redis://redis:6379/0

# API Security
ALLOWED_HOSTS=localhost,127.0.0.1,api
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ==============================================================================
# PRODUCTION NOTES
# ==============================================================================
# For production deployment:
# 1. Change ENVIRONMENT=production
# 2. Generate new ANTHROPIC_API_KEY with production credentials
# 3. Generate new encryption keys with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# 4. Use strong PostgreSQL password (min 20 chars, mix of upper/lower/numbers/symbols)
# 5. Set proper CORS_ORIGINS to match your domain
# 6. Use PostgreSQL instead of SQLite
# 7. Enable HTTPS/TLS
# 8. Set up proper backup strategy for postgres_data volume
