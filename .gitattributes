# Ensure consistent line endings across platforms
* text=auto

# Python files - use LF on all platforms
*.py text eol=lf
*.pyi text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# YAML/JSON
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf

# Markdown
*.md text eol=lf

# Docker
Dockerfile* text eol=lf
