# Socrates API Environment Variables Example
# Copy this file to .env and fill in the actual values
# IMPORTANT: .env is in .gitignore - never commit it with actual secrets

# ========================================
# REQUIRED - Must be set for API to work
# ========================================

# Encryption Key for sensitive data (API keys, tokens, etc)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SOCRATES_ENCRYPTION_KEY=your-secure-encryption-key-here

# ========================================
# OPTIONAL - Has sensible defaults
# ========================================

# Environment setting (development, staging, production)
ENVIRONMENT=development

# Database location
SOCRATES_DATA_DIR=${HOME}/.socrates

# API Configuration
API_HOST=127.0.0.1
API_PORT=8000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Debug mode
DEBUG=false

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Redis (optional, for caching)
REDIS_URL=redis://localhost:6379

# Anthropic API Key (optional, for code generation)
ANTHROPIC_API_KEY=your-anthropic-key-here

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60
