# Socrates Environment Configuration
#
# Copy this file to .env and fill in the required values
# This file documents all environment variables used by Socrates
#
# For development, you can run: python setup_env.py
# This will auto-generate a .env file with sensible defaults

# ==============================================================================
# CORE CONFIGURATION
# ==============================================================================

# Deployment environment
# Valid values: development, staging, production
# Default: Auto-detected from hostname
ENVIRONMENT=development

# ==============================================================================
# AUTHENTICATION & SECURITY
# ==============================================================================

# JWT Secret Key for signing authentication tokens
# CRITICAL: Must be at least 32 characters in production
# Default: Generated by setup_env.py if not set
# Example: your-very-secret-jwt-key-here-minimum-32-characters
JWT_SECRET_KEY=your-secret-jwt-key-here

# Database encryption key (for encrypted fields)
# Optional: Only needed if SECURITY_DATABASE_ENCRYPTION=true
# Should be 32 characters
DATABASE_ENCRYPTION_KEY=

# Enable database field-level encryption
# Valid values: true, false
# Default: false
SECURITY_DATABASE_ENCRYPTION=false

# ==============================================================================
# LLM & EXTERNAL SERVICES
# ==============================================================================

# Anthropic API Key for Claude LLM
# Required for: Code generation, quality analysis, learning guidance
# Get key from: https://console.anthropic.com/
# Default: None (optional for some operations)
ANTHROPIC_API_KEY=

# ==============================================================================
# SERVER CONFIGURATION
# ==============================================================================

# API Server Host
# Default: 127.0.0.1 (localhost only)
# Use 0.0.0.0 to accept remote connections
SOCRATES_API_HOST=127.0.0.1

# API Server Port
# Default: 8000
# Can be auto-detected from auto_detect_ports in main.py
SOCRATES_API_PORT=8000

# Enable auto-reload on file changes (development only)
# Valid values: true, false
# Default: false
SOCRATES_API_RELOAD=false

# ==============================================================================
# DATA & STORAGE
# ==============================================================================

# Data directory for SQLite databases and local storage
# Default: ~/.socrates
# This directory will contain:
#   - api_projects.db (API layer projects and users)
#   - projects.db (core system domain model)
# Example: /var/lib/socrates or ~/socrates-data
SOCRATES_DATA_DIR=~/.socrates

# ==============================================================================
# DATABASE CONFIGURATION (Optional - PostgreSQL)
# ==============================================================================

# Main database connection string (for future PostgreSQL migration)
# Example: postgresql://user:password@localhost:5432/socrates
# If not set, uses SQLite at $SOCRATES_DATA_DIR/projects.db
DATABASE_URL=

# Read replica URLs (comma-separated, for analytics/reporting)
# Example: postgresql://user:password@replica1:5432/socrates,postgresql://user:password@replica2:5432/socrates
# Only used if DATABASE_URL is set
DATABASE_REPLICA_URLS=

# Database connection pool size
# Default: 5 for local SQLite, 10+ for PostgreSQL
DATABASE_POOL_SIZE=5

# Database max overflow connections
# Default: 10
DATABASE_MAX_OVERFLOW=10

# ==============================================================================
# CACHING & PERFORMANCE
# ==============================================================================

# Redis connection string for caching and rate limiting
# Example: redis://localhost:6379/0 or redis://redis:6379
# Default: redis://redis:6379 (expected to be running)
# If Redis is unavailable, the system will degrade gracefully
REDIS_URL=redis://redis:6379

# Redis database number
# Default: 0
REDIS_DB=0

# Enable query profiling and optimization metrics
# Valid values: true, false
# Default: true (development), false (production)
ENABLE_QUERY_PROFILING=true

# ==============================================================================
# FEATURE FLAGS
# ==============================================================================

# Enable rate limiting
# Valid values: true, false
# Default: true
# Rate limits: 5 requests/minute for auth endpoints, 100/minute for API
ENABLE_RATE_LIMITING=true

# Enable Prometheus metrics endpoint
# Valid values: true, false
# Default: true
# Metrics available at: /metrics
ENABLE_METRICS=true

# Enable WebSocket support for real-time updates
# Valid values: true, false
# Default: true
ENABLE_WEBSOCKET=true

# ==============================================================================
# CORS (Cross-Origin Resource Sharing)
# ==============================================================================

# Allowed origins for CORS (comma-separated)
# Default: localhost variants in development
# Production should restrict to your domain
# Examples:
#   - http://localhost:3000 (frontend dev)
#   - https://example.com (production)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:5173,http://127.0.0.1:3000

# ==============================================================================
# LOGGING & DEBUGGING
# ==============================================================================

# Log level
# Valid values: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Default: INFO (development), WARNING (production)
LOG_LEVEL=INFO

# Enable debug mode (extra logging, slower performance)
# Valid values: true, false
# Default: false
DEBUG=false

# ==============================================================================
# API CONFIGURATION
# ==============================================================================

# API Title (shown in OpenAPI/Swagger docs)
# Default: Socrates API
API_TITLE=Socrates API

# API Version
# Default: 0.1.0
API_VERSION=0.1.0

# API Documentation URL (for OpenAPI)
# Default: /docs
API_DOCS_URL=/docs

# ==============================================================================
# INITIALIZATION BEHAVIOR
# ==============================================================================

# Skip database initialization (if database already initialized)
# Valid values: true, false
# Default: false
SKIP_DB_INIT=false

# Wait for dependencies (Redis, PostgreSQL) before starting
# Valid values: true, false
# Default: false (fail fast if dependencies unavailable)
WAIT_FOR_DEPENDENCIES=false

# Maximum wait time for dependencies (in seconds)
# Default: 30
DEPENDENCIES_TIMEOUT=30

# ==============================================================================
# FRONTEND CONFIGURATION (If running in full-stack mode)
# ==============================================================================

# Frontend development server port
# Default: 3000
FRONTEND_PORT=3000

# Frontend development server host
# Default: 127.0.0.1
FRONTEND_HOST=127.0.0.1

# ==============================================================================
# NOTES
# ==============================================================================

# 1. For development:
#    - Run: python setup_env.py
#    - This auto-generates .env with required defaults
#
# 2. For production:
#    - Copy deployment/configurations/.env.production.example to .env
#    - Set all security variables (JWT_SECRET_KEY, ANTHROPIC_API_KEY)
#    - Use strong, unique values
#    - Never commit .env to version control
#
# 3. For local secrets (not in version control):
#    - See: deployment/configurations/.env.local.example
#    - Add to .env.local (not tracked by git)
#
# 4. Environment variable precedence:
#    - Command-line arguments override env vars
#    - Environment variables override defaults
#    - Defaults are defined in the code
#
# 5. Database migration (to PostgreSQL):
#    - Set DATABASE_URL to PostgreSQL connection string
#    - Run: python scripts/migrate_to_postgres.py
#    - Both SQLite and PostgreSQL can coexist during migration
