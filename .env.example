# Socrates Production Environment Configuration (Template)
# Copy this file to .env and fill in your own values
# IMPORTANT: Never commit .env to version control!

# ============================================================================
# ENCRYPTION & SECURITY (CRITICAL - Generate unique values for each environment)
# ============================================================================

# Encryption key for storing provider API keys and sensitive data in database
# Generate: python3 -c "import secrets, base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
SOCRATES_ENCRYPTION_KEY=your-secure-random-key-here

# Encryption key for database-level encryption
# Generate: python3 -c "import secrets, base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
DATABASE_ENCRYPTION_KEY=your-secure-random-key-here

# JWT Secret Key - CRITICAL for session persistence across container restarts
# MUST BE CONSISTENT across all deployments to prevent invalidating user sessions when containers restart
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=your-secure-random-jwt-secret-here

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# PostgreSQL connection string (production-recommended)
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://socrates:your-secure-password@postgres:5432/socrates_db

# PostgreSQL credentials
POSTGRES_USER=socrates
POSTGRES_PASSWORD=your-secure-password
POSTGRES_DB=socrates_db

# ============================================================================
# REDIS CACHE CONFIGURATION
# ============================================================================

# Redis connection string
REDIS_URL=redis://redis:6379/0

# ============================================================================
# API CONFIGURATION
# ============================================================================

# API host binding (0.0.0.0 for Docker, localhost for local)
SOCRATES_API_HOST=0.0.0.0

# API port
SOCRATES_API_PORT=8000

# Allowed hosts for CORS and security
ALLOWED_HOSTS=localhost,127.0.0.1,api,socrates.example.com

# CORS allowed origins (update with your domain)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://socrates.example.com

# ============================================================================
# RUNTIME CONFIGURATION
# ============================================================================

# Environment (development, staging, production)
ENVIRONMENT=production

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Python configuration
PYTHONUNBUFFERED=1

# ============================================================================
# PROVIDER CONFIGURATION (Optional - can also add via UI)
# ============================================================================

# Note: Provider API keys are now stored in the database via the UI
# The ANTHROPIC_API_KEY environment variable is NOT required
# Add your Anthropic API key via the Socrates UI instead

# ANTHROPIC_API_KEY=sk-ant-xxxxx  # Leave empty, add via UI

# ============================================================================
# OPTIONAL: ADDITIONAL CONFIGURATION
# ============================================================================

# Maximum request size (in MB)
MAX_REQUEST_SIZE=50

# Session timeout (in seconds)
SESSION_TIMEOUT=3600

# Token expiration (in hours)
JWT_EXPIRATION_HOURS=24
